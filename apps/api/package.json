{
  "name": "@agent-os/api",
  "version": "1.0.0",
  "private": true,
  "description": "Agent OS HTTP API. Fastify-based service exposing health, version, and runtime endpoints.",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agent-os",
    "api",
    "fastify"
  ],
  "author": "Agent OS Maintainers",
  "license": "Apache-2.0",
  "agent-os": {
    "layer": 4,
    "audience": "internal",
    "kind": "app"
  },
  "dependencies": {
    "@agent-os/auth": "workspace:*",
    "@agent-os/core": "workspace:*",
    "@agent-os/graphiti": "workspace:*",
    "@agent-os/hermes": "workspace:*",
    "@agent-os/runtime": "workspace:*",
    "@agent-os/observability": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/sensible": "^6.0.1",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.1",
    "vitest": "^4.1.9"
  }
}

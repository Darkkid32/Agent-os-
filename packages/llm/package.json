{
  "name": "@agent-os/llm",
  "version": "1.0.0",
  "private": true,
  "description": "Vendor-agnostic LLM abstraction for Agent OS. Provider interface, registry, factory, and observability.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agent-os",
    "llm",
    "provider",
    "abstraction",
    "openai"
  ],
  "author": "Agent OS Maintainers",
  "license": "Apache-2.0",
  "agent-os": {
    "layer": 2,
    "audience": "internal"
  },
  "dependencies": {
    "@agent-os/core": "workspace:*",
    "@agent-os/config": "workspace:*",
    "@agent-os/observability": "workspace:*",
    "openai": "^4.78.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "vitest": "^4.1.9"
  }
}

{
  "name": "@agent-os/core",
  "version": "1.0.0",
  "private": true,
  "description": "Core primitives, types, and utilities for the Agent OS runtime and platform.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.ts",
      "import": "./dist/test-utils.js",
      "default": "./dist/test-utils.js"
    },
    "./kernel-permissions": {
      "types": "./dist/kernel-permissions.d.ts",
      "import": "./dist/kernel-permissions.js",
      "default": "./dist/kernel-permissions.js"
    },
    "./adapter-metadata": {
      "types": "./dist/adapter-metadata.d.ts",
      "import": "./dist/adapter-metadata.js",
      "default": "./dist/adapter-metadata.js"
    },
    "./adapter-errors": {
      "types": "./dist/adapter-errors.d.ts",
      "import": "./dist/adapter-errors.js",
      "default": "./dist/adapter-errors.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agent-os",
    "core",
    "typescript"
  ],
  "author": "Agent OS Maintainers",
  "license": "Apache-2.0",
  "agent-os": {
    "layer": 1,
    "audience": "internal"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}

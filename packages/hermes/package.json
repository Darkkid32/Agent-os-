{
  "name": "@agent-os/hermes",
  "version": "0.1.0",
  "private": true,
  "description": "Hermes integration layer placeholder. Implementation ships in Phase 2.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/hermes-mock.d.ts",
      "import": "./dist/test-utils/hermes-mock.js",
      "default": "./dist/test-utils/hermes-mock.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agent-os",
    "hermes"
  ],
  "author": "Agent OS Maintainers",
  "license": "Apache-2.0",
  "agent-os": {
    "layer": 4,
    "audience": "internal"
  },
  "dependencies": {
    "@agent-os/core": "workspace:*",
    "@agent-os/event-bus": "workspace:*",
    "@agent-os/observability": "workspace:*",
    "@agent-os/runtime": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}

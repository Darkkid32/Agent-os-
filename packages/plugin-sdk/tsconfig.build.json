{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "**/node_modules", "**/dist"],
  "references": [{ "path": "../core/tsconfig.build.json" }, { "path": "../plugins/tsconfig.build.json" }]
}

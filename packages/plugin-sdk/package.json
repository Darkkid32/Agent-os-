{
  "name": "@agent-os/plugin-sdk",
  "version": "1.0.0",
  "private": true,
  "description": "Plugin SDK for Agent OS — helpers, templates, and examples for building plugins.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./templates/*": {
      "types": "./dist/templates/*.d.ts",
      "import": "./dist/templates/*.js",
      "default": "./dist/templates/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agent-os",
    "plugin-sdk",
    "sdk"
  ],
  "author": "Agent OS Maintainers",
  "license": "Apache-2.0",
  "agent-os": {
    "layer": 3,
    "audience": "external"
  },
  "dependencies": {
    "@agent-os/core": "workspace:*",
    "@agent-os/plugins": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}

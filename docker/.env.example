# =============================================================================
# Agent OS — Environment template.
#
# Copy to `.env` and fill in values.  Never commit `.env`.
#
# Defaults shown below match the production compose stack in
# `docker/docker-compose.yml` (postgres user/db `agent_os`, redis on 6379).
# In CI the tests run with NO secrets, so OpenRouter is intentionally empty
# there.
# =============================================================================

# ----- Runtime ------------------------------------------------------------
NODE_ENV=development                # one of: development | test | production
PORT=4000                          # API HTTP port (api service ignores 3000)
LOG_LEVEL=info                     # trace | debug | info | warn | error | fatal

# ----- Database -----------------------------------------------------------
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://agent_os:agent_os@localhost:5432/agent_os
POSTGRES_DB=agent_os
POSTGRES_USER=agent_os
POSTGRES_PASSWORD=agent_os

# ----- Cache / Eventing ---------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----- LLM Provider -------------------------------------------------------
# Phase 2 will use this to authenticate against OpenRouter's chat completions
# API.  Leave empty in CI; required for production model invocations.
OPENROUTER_API_KEY=

# ----- Observability ------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=agent-os
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ----- Dashboard ----------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
